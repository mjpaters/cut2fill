    "administering_department": "Department of Regional Development, Manufacturing and Water (DRDMW)",
    "data_currency": "Updated quarterly, last update January 2026",
    "extraction_date": "2026-03-25",
    "notes": "RPP data from CKAN datastore API; QMAN data from CKAN datastore API. Raw CSVs also saved locally."
  },
